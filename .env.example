# Public Compose configuration. Secrets are generated as files under ./secrets;
# never put passwords, tokens, or private keys in this file.
GUARDIAN_DOMAIN=guardian.example.com
GUARDIAN_AGENT_DOMAIN=agents.guardian.example.com
ACME_EMAIL=operator@example.com
GUARDIAN_BROWSER_ORIGIN=https://guardian.example.com
GUARDIAN_AGENT_BIND_ADDRESS=0.0.0.0
GUARDIAN_AGENT_PORT=8444
GUARDIAN_AGENT_GATEWAY_URL=https://agents.guardian.example.com:8444
GUARDIAN_AGENT_CERTIFICATE_TTL_HOURS=720
GUARDIAN_ENROLLMENT_ATTEMPTS_PER_10M=10
GUARDIAN_METRIC_RETENTION_DAYS=7
GUARDIAN_SERVICE_RESULT_RETENTION_DAYS=30
GUARDIAN_MAX_METRIC_ROWS_PER_HOST=10080
GUARDIAN_MAX_RESULTS_PER_CHECK=43200
GUARDIAN_EXTERNAL_NOTIFICATIONS_ENABLED=false
GUARDIAN_SECRETS_DIR=./secrets
GUARDIAN_GATEWAY_PKI_DIR=./secrets/gateway-pki
VPS_GUARDIAN_SOURCE_COMMIT=0000000000000000000000000000000000000000
VPS_GUARDIAN_DATABASE_IMAGE=vps-guardian-postgres:0.1.0-alpha.1
VPS_GUARDIAN_CONTROLLER_IMAGE=vps-guardian-controller:0.1.0-alpha.1
VPS_GUARDIAN_BACKUP_IMAGE=vps-guardian-controller:0.1.0-alpha.1
VPS_GUARDIAN_WEB_IMAGE=vps-guardian-web:0.1.0-alpha.1
RESTIC_REPOSITORY=
