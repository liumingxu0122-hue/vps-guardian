GUARDIAN_DOMAIN=guardian.example.com
GUARDIAN_AGENT_DOMAIN=agent.guardian.example.com
GUARDIAN_AGENT_BIND_ADDRESS=0.0.0.0
GUARDIAN_AGENT_PORT=8444
VPS_GUARDIAN_SOURCE_COMMIT=replace-with-reviewed-40-character-git-commit
VPS_GUARDIAN_CONTROLLER_IMAGE=registry.example.com/vps-guardian/controller@sha256:replace-with-reviewed-64-hex-digest
VPS_GUARDIAN_BACKUP_IMAGE=registry.example.com/vps-guardian/backup@sha256:replace-with-reviewed-64-hex-digest
VPS_GUARDIAN_WEB_IMAGE=registry.example.com/vps-guardian/web@sha256:replace-with-reviewed-64-hex-digest
GUARDIAN_GATEWAY_PKI_DIR=/etc/vps-guardian/secrets/gateway-pki
ACME_EMAIL=admin@example.com
RESTIC_REPOSITORY=s3:https://object.example.com/guardian-backups
VPS_GUARDIAN_BACKUP_TIMEOUT_SECONDS=14400
VPS_GUARDIAN_BACKUP_MIN_FREE_BYTES=1073741824
GUARDIAN_S3_ACCESS_KEY_ID_FILE=./secrets/runtime/aws-access-key-id
GUARDIAN_S3_SECRET_ACCESS_KEY_FILE=./secrets/runtime/aws-secret-access-key
GUARDIAN_S3_REGION_FILE=./secrets/runtime/aws-region
