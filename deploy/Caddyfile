{
  admin off
  email {$ACME_EMAIL}
}

{$GUARDIAN_DOMAIN} {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Content-Security-Policy "default-src 'self'; connect-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; frame-ancestors 'none'; base-uri 'none'"
  }

  @controller path /api/* /health /docs* /openapi.json
  handle @controller {
    reverse_proxy controller:8090 {
      header_up -X-Guardian-Proxy-Auth
      header_up -X-Guardian-Client-Certificate-Der
      header_up -X-Client-Cert-Fingerprint
      header_up -X-Forwarded-Client-Cert
      header_up -X-SSL-Client-Cert
    }
  }

  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }
}
