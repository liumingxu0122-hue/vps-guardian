{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vps-guardian.invalid/schemas/trust-material-v2.schema.json",
  "title": "VPS Guardian trust material v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifacts", "contains_private_material", "schema"],
  "properties": {
    "schema": {"const": "vps-guardian-trust-material/v2"},
    "contains_private_material": {"const": false},
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_ca", "agent_crl", "controller_public_key", "gateway_certificate", "gateway_issuer_ca"],
      "properties": {
        "agent_ca": {"$ref": "#/$defs/certificate", "properties": {"artifact": {"const": "agent-ca.crt"}}},
        "gateway_certificate": {"$ref": "#/$defs/certificate", "properties": {"artifact": {"const": "agent-gateway.crt"}}},
        "gateway_issuer_ca": {"$ref": "#/$defs/certificate", "properties": {"artifact": {"const": "agent-gateway-issuer-ca.crt"}}},
        "agent_crl": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact", "artifact_sha256", "authority_key_identifier", "crl_number", "issuer", "next_update", "revoked_certificate_count", "revoked_serials_sha256", "signature_algorithm_oid", "this_update"],
          "properties": {
            "artifact": {"const": "agent-ca.crl"},
            "artifact_sha256": {"$ref": "#/$defs/sha256"},
            "authority_key_identifier": {"$ref": "#/$defs/hex"},
            "crl_number": {"type": "string", "pattern": "^[0-9]{1,40}$"},
            "issuer": {"$ref": "#/$defs/name"},
            "next_update": {"$ref": "#/$defs/utc_time"},
            "revoked_certificate_count": {"type": "integer", "minimum": 0},
            "revoked_serials_sha256": {"$ref": "#/$defs/sha256"},
            "signature_algorithm_oid": {"$ref": "#/$defs/oid"},
            "this_update": {"$ref": "#/$defs/utc_time"}
          }
        },
        "controller_public_key": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact", "artifact_sha256", "encoding", "raw_sha256", "raw_size"],
          "properties": {
            "artifact": {"const": "controller-public-key"},
            "artifact_sha256": {"$ref": "#/$defs/sha256"},
            "encoding": {"const": "base64-raw-ed25519"},
            "raw_sha256": {"$ref": "#/$defs/sha256"},
            "raw_size": {"const": 32}
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "hex": {"type": "string", "pattern": "^(?:[a-f0-9]{2})+$"},
    "name": {"type": "string", "minLength": 1, "maxLength": 2048},
    "oid": {"type": "string", "pattern": "^[0-2](\\.[0-9]+)+$"},
    "utc_time": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "artifact_sha256", "authority_key_identifier", "der_sha256", "issuer", "not_after", "not_before", "serial_number", "signature_algorithm_oid", "subject", "subject_key_identifier"],
      "properties": {
        "artifact": {"type": "string"},
        "artifact_sha256": {"$ref": "#/$defs/sha256"},
        "authority_key_identifier": {"$ref": "#/$defs/hex"},
        "der_sha256": {"$ref": "#/$defs/sha256"},
        "issuer": {"$ref": "#/$defs/name"},
        "not_after": {"$ref": "#/$defs/utc_time"},
        "not_before": {"$ref": "#/$defs/utc_time"},
        "serial_number": {"type": "string", "pattern": "^[0-9A-F]+$"},
        "signature_algorithm_oid": {"$ref": "#/$defs/oid"},
        "subject": {"$ref": "#/$defs/name"},
        "subject_key_identifier": {"$ref": "#/$defs/hex"}
      }
    }
  }
}
